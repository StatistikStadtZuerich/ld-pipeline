{
  "type": "AdaptiveCard",
  "$schema": "https://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "🚨",
              "style": "heading"
            }
          ],
          "verticalContentAlignment": "Top"
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "${environment} Pipeline fehlgeschlagen",
              "wrap": true,
              "style": "heading"
            }
          ]
        }
      ]
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Run-ID",
          "value": "$runId"
        },
        {
          "title": "Exit-Code",
          "value": "$exitCode"
        },
        {
          "title": "Branch",
          "value": "$branch"
        },
        {
          "title": "Environment",
          "value": "$environment"
        },
        {
          "title": "Target-Environment",
          "value": "$targetEnv"
        }
      ]
    }
  ],
  "msteams": {
    "width": "full"
  }
}