DROP VIEW IF EXISTS [{{ 'dbo.view_dimension_hierarchy' | view_name }}];

GO

CREATE VIEW [{{ 'dbo.view_dimension_hierarchy' | view_name }}] AS
    SELECT 
        h.GRUPPENCODE as child_code,
        h.PARENTCODE as parent_code,
        TRIM(value) AS hierarchie_relation
    FROM [{{ 'dbo.pipe_HDBGruppenliste' | pipe_table_name }}] h
    JOIN [{{ 'dbo.pipe_HDBGruppenliste' | pipe_table_name }}] p
        ON p.GRUPPENCODE = h.PARENTCODE
        CROSS APPLY STRING_SPLIT(p.HIERARCHIEIDLIST, ';')
;