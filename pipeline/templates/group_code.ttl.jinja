<https://ld.stadt-zuerich.ch/statistics/code/{{ term_code|uri_encode }}> a <https://schema.org/DefinedTerm> ;
    <https://schema.org/name> {{ title|literal_encode }} ;
    <https://schema.org/description> {{ description|literal_encode }} ;
    <https://schema.org/termCode> {{ term_code|literal_encode }} ;
    <https://schema.org/position> {{ position|literal_encode }} ;
    <https://schema.org/isPartOf> <https://ld.stadt-zuerich.ch/statistics/code/{{ part_of|uri_encode }}> ;
    <https://schema.org/inDefinedTermSet> <https://ld.stadt-zuerich.ch/statistics/termset/{{ term_group_code|uri_encode }}> ;
    {% if term_sets %}
	  {% for term_set in term_sets.split(';') %}
		<https://schema.org/inDefinedTermSet> <https://ld.stadt-zuerich.ch/statistics/termset/{{ term_set|uri_encode }}> ;
		{% endfor %}
	  {% endif %}
    .
