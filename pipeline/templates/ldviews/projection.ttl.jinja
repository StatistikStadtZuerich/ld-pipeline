<https://ld.stadt-zuerich.ch/statistics/view/{{ id|uri_encode }}> <https://cube.link/view/projection> [
        <https://cube.link/view/columns> ({{ projected_bnodes | join(' ') }})
    ] .
{% for attribute in attributes %}
<https://ld.stadt-zuerich.ch/statistics/view/{{ id|uri_encode }}> <https://ld.stadt-zuerich.ch/schema/dataAttribute> [
       a "https://ld.stadt-zuerich.ch/schema/Attribute";
       <https://schema.org/alternateName> {{ attribute.alternate_name | literal_encode }};
       <https://schema.org/description> {{ attribute.description | literal_encode }};
       <https://schema.org/name> {{ attribute.name | literal_encode }};
       <https://schema.org/position> {{ attribute.position }}
     ] .
{% endfor %}


